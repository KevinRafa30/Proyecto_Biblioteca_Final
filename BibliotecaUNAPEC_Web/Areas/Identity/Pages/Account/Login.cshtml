@page
@model LoginModel

@{
    ViewData["Title"] = "Acceso al Sistema";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="text-center mb-4">
                <h2 class="fw-bold text-primary mb-0">Gestión Bibliotecaria</h2>
                <p class="text-muted small text-uppercase" style="letter-spacing: 1px;">Universidad UNAPEC</p>
            </div>

            <div class="card rounded-1 border shadow-none">
                <div class="card-header bg-light border-bottom p-3">
                    <h6 class="mb-0 fw-bold text-dark text-uppercase small text-center">
                        <i class="bi bi-shield-lock me-2 text-primary"></i>Inicio de Sesión
                    </h6>
                </div>
                <div class="card-body p-4">
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small" role="alert"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label small fw-bold text-muted text-uppercase">Correo Institucional</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-secondary-subtle">
                                    <i class="bi bi-envelope"></i>
                                </span>
                                <input asp-for="Input.Email" class="form-control rounded-end-1 border-secondary-subtle" autocomplete="username" placeholder="nombre@unapec.edu.do" />
                            </div>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label small fw-bold text-muted text-uppercase">Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-secondary-subtle">
                                    <i class="bi bi-key"></i>
                                </span>
                                <input asp-for="Input.Password" class="form-control rounded-end-1 border-secondary-subtle" autocomplete="current-password" placeholder="••••••••" />
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>
                        
                        <div class="checkbox mb-4">
                            <label asp-for="Input.RememberMe" class="form-label small text-muted">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                Mantener sesión iniciada
                            </label>
                        </div>
                        
                        <div class="mb-3">
                            <button id="login-submit" type="submit" class="w-100 btn btn-primary btn-lg rounded-1 fw-bold border-0">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Entrar al Sistema
                            </button>
                        </div>
                        
                        <div class="text-center pt-3 border-top mt-4">
                            <p class="mb-2">
                                <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none small">¿Olvidaste tu contraseña?</a>
                            </p>
                            <p class="mb-0">
                                <span class="text-muted small">¿No tienes cuenta?</span>
                                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-bold text-primary text-decoration-none small">Regístrate aquí</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>

            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="mt-4 text-center">
                    <p class="text-muted small text-uppercase mb-3">O entrar con</p>
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit" class="btn btn-outline-secondary w-100 mb-2 rounded-1" name="provider" value="@provider.Name">
                                <i class="bi bi-google me-2"></i> @provider.DisplayName
                            </button>
                        }
                    </form>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}