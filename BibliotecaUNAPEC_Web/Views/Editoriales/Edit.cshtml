@model BibliotecaUNAPEC_Web.Models.Editoriale

@{
    ViewData["Title"] = "Editar Editorial";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-primary">Editar Editorial</h2>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Listado
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0">Información de la Editorial</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="IdEditorial" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nombre" class="form-label fw-bold">Nombre de la Editorial</label>
                                <input asp-for="Nombre" class="form-control" placeholder="Ej. Editorial Santillana" />
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Pais" class="form-label fw-bold">País de Origen</label>
                                <input asp-for="Pais" class="form-control" placeholder="Ej. España, México..." />
                                <span asp-validation-for="Pais" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="text-muted" />

                        <div class="form-group mb-4">
                            <label class="form-label fw-bold d-block">Estado de Operación</label>
                            <div class="form-check form-switch custom-switch">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       name="Estado" id="switchEstado" value="true"
                                       @(Model.Estado == true ? "checked=\"checked\"" : "")>

                                <input type="hidden" name="Estado" value="false" />

                                <label class="form-check-label text-muted" for="switchEstado">
                                    Editorial activa para nuevas entradas de catálogo
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="bi bi-save"></i> Guardar Cambios
                            </button>
                            
                            <a asp-action="Delete" asp-route-id="@Model.IdEditorial" class="btn btn-outline-danger">
                                <i class="bi bi-trash"></i> Eliminar Registro
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}