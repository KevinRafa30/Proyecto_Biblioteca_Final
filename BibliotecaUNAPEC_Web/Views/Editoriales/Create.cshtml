@model BibliotecaUNAPEC_Web.Models.Editoriale

@{
    ViewData["Title"] = "Registrar Editorial";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Registrar Nueva Editorial</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <h5 class="text-secondary mb-3">Información de la Editorial</h5>

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Nombre" class="control-label fw-bold">Nombre de la Empresa Editorial</label>
                                <input asp-for="Nombre" class="form-control" placeholder="Ej. Editorial Santillana" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Pais" class="control-label fw-bold">País de Origen</label>
                                <input asp-for="Pais" class="form-control" placeholder="Ej. República Dominicana" />
                                <span asp-validation-for="Pais" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Estado" class="control-label fw-bold">Estado de Disponibilidad</label>
                                <select asp-for="Estado" class="form-select">
                                    <option value="true">Activa</option>
                                    <option value="false">Inactiva</option>
                                </select>
                                <span asp-validation-for="Estado" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">Volver al Listado</a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">Guardar Editorial</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}