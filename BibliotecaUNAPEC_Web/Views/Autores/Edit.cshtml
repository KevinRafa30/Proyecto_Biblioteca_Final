@model BibliotecaUNAPEC_Web.Models.Autore

@{
    ViewData["Title"] = "Editar Autor";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-primary">Editar Autor</h2>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Listado
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0">Información del Autor</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="IdAutor" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nombre" class="form-label fw-bold">Nombre</label>
                                <input asp-for="Nombre" class="form-control" placeholder="Ej. Gabriel" />
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Apellido" class="form-label fw-bold">Apellido</label>
                                <input asp-for="Apellido" class="form-control" placeholder="Ej. García Márquez" />
                                <span asp-validation-for="Apellido" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Nacionalidad" class="form-label fw-bold">Nacionalidad</label>
                            <input asp-for="Nacionalidad" class="form-control" placeholder="Ej. Colombiano, Dominicano..." />
                            <span asp-validation-for="Nacionalidad" class="text-danger small"></span>
                        </div>

                        <hr class="text-muted" />

                        <div class="form-group mb-4">
                            <label class="form-label fw-bold d-block">Estado del Autor</label>
                            <div class="form-check form-switch custom-switch">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       name="Estado" id="switchEstado" value="true"
                                       @(Model.Estado == true ? "checked=\"checked\"" : "")>

                                <input type="hidden" name="Estado" value="false" />

                                <label class="form-check-label text-muted" for="switchEstado">
                                    Autor activo para nuevas publicaciones
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="bi bi-save"></i> Guardar Cambios
                            </button>
                            <a asp-action="Delete" asp-route-id="@Model.IdAutor" class="btn btn-outline-danger">
                                <i class="bi bi-trash"></i> Eliminar Registro
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}