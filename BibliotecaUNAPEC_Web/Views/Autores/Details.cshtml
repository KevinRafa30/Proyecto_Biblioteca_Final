@model BibliotecaUNAPEC_Web.Models.Autore

@{
    ViewData["Title"] = "Detalles del Autor";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-primary">Información del Autor</h2>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Listado
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Perfil del Autor</h5>
                    <span class="badge bg-secondary">ID: @Model.IdAutor</span>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-sm-4 fw-bold text-muted text-uppercase small">Nombre Completo:</div>
                        <div class="col-sm-8 fs-4 fw-bold text-dark">
                            @Model.Nombre @Model.Apellido
                        </div>
                    </div>

                    <hr class="text-light" />

                    <div class="row mb-4">
                        <div class="col-sm-4 fw-bold text-muted text-uppercase small">Nacionalidad:</div>
                        <div class="col-sm-8 fs-5">
                            <i class="bi bi-globe text-primary"></i> @Model.Nacionalidad
                        </div>
                    </div>

                    <hr class="text-light" />

                    <div class="row mb-2 align-items-center">
                        <div class="col-sm-4 fw-bold text-muted text-uppercase small">Estado Actual:</div>
                        <div class="col-sm-8">
                            @if (Model.Estado == true)
                            {
                                <span class="badge bg-success py-2 px-3">
                                    <i class="bi bi-check-circle-fill"></i> Autor Activo
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger py-2 px-3">
                                    <i class="bi bi-x-circle-fill"></i> Autor Inactivo
                                </span>
                            }
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-top-0 p-3 text-end">
                    <a asp-action="Edit" asp-route-id="@Model?.IdAutor" class="btn btn-primary px-4 shadow-sm">
                        <i class="bi bi-pencil"></i> Editar Información
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>