@model BibliotecaUNAPEC_Web.Models.Autore

@{
    ViewData["Title"] = "Eliminar Autor";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-danger">Eliminar Autor</h2>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Listado
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0">¿Está seguro de que desea eliminar este autor?</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-muted">Nombre</label>
                            <div class="form-control-plaintext border-bottom">@Model.Nombre</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-muted">Apellido</label>
                            <div class="form-control-plaintext border-bottom">@Model.Apellido</div>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label fw-bold text-muted">Nacionalidad</label>
                        <div class="form-control-plaintext border-bottom">@Model.Nacionalidad</div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label fw-bold d-block text-muted">Estado del Autor</label>
                        @if (Model.Estado == true)
                        {
                            <span class="badge bg-success py-2 px-3">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger py-2 px-3">Inactivo</span>
                        }
                    </div>

                    <hr class="text-muted" />

                    <div class="alert alert-warning border-0 shadow-sm d-flex align-items-center" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
                        <div>
                            <strong>Atención:</strong> Esta acción eliminará permanentemente los datos del autor y no se puede deshacer.
                        </div>
                    </div>

                    <form asp-action="Delete">
                        @* Usamos 'name="id"' para asegurar compatibilidad con el parámetro del controlador *@
                        <input type="hidden" name="id" value="@Model.IdAutor" />

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-danger btn-lg shadow-sm">
                                <i class="bi bi-trash"></i> Confirmar Eliminación
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>