@model IEnumerable<BibliotecaUNAPEC_Web.Models.Autore>

@{
    ViewData["Title"] = "Mantenimiento de Autores";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">Mantenimiento de Autores</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">Registrar Nuevo Autor</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Nombre</th>
                            <th>Apellido</th>
                            <th>Nacionalidad</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle fw-bold">@item.Nombre</td>
                                <td class="align-middle">@item.Apellido</td>
                                <td class="align-middle">@item.Nacionalidad</td>
                                <td class="align-middle">
                                    @* Estado del autor *@
                                    @if (item.Estado == true)
                                    {
                                        <span class="badge bg-success py-2 px-3">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger py-2 px-3">Inactivo</span>
                                    }
                                </td>
                                <td class="align-middle text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.IdAutor" class="btn btn-sm btn-outline-primary">Editar</a>
                                        <a asp-action="Details" asp-route-id="@item.IdAutor" class="btn btn-sm btn-outline-secondary">Detalles</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>