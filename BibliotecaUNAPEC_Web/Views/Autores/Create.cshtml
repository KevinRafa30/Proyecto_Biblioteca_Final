@model BibliotecaUNAPEC_Web.Models.Autore

@{
    ViewData["Title"] = "Registrar Autor";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Registrar Nuevo Autor</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <h5 class="text-secondary mb-3">Datos del Autor</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nombre" class="control-label fw-bold">Nombre</label>
                                <input asp-for="Nombre" class="form-control" placeholder="Ej. Gabriel García" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Apellido" class="control-label fw-bold">Apellido</label>
                                <input asp-for="Apellido" class="form-control" placeholder="Ej. Márquez" />
                                <span asp-validation-for="Apellido" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nacionalidad" class="control-label fw-bold">Nacionalidad</label>
                                <input asp-for="Nacionalidad" class="form-control" placeholder="Ej. Colombiana" />
                                <span asp-validation-for="Nacionalidad" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Estado" class="control-label fw-bold">Estado en Sistema</label>
                                <select asp-for="Estado" class="form-select">
                                    <option value="true">Activo</option>
                                    <option value="false">Inactivo</option>
                                </select>
                                <span asp-validation-for="Estado" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">Volver al Listado</a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">Guardar Autor</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}