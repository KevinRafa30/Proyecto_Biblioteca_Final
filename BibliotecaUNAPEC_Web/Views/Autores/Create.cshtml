@model BibliotecaUNAPEC_Web.Models.Autore

@{
    ViewData["Title"] = "Registrar Autor";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h2 class="fw-bold text-primary mb-0">Gestión de Autores</h2>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Volver al Listado
                </a>
            </div>

            <div class="card rounded-1 border shadow-none">
                <div class="card-header bg-light border-bottom p-3">
                    <h6 class="mb-0 fw-bold text-dark text-uppercase small">
                        <i class="bi bi-person-plus me-2 text-primary"></i>Alta de Escritor / Académico
                    </h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="row mb-4">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nombre" class="form-label small fw-bold text-muted text-uppercase">Nombre</label>
                                <input asp-for="Nombre" class="form-control rounded-1 border-secondary-subtle" placeholder="Ej. Gabriel García" />
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Apellido" class="form-label small fw-bold text-muted text-uppercase">Apellido</label>
                                <input asp-for="Apellido" class="form-control rounded-1 border-secondary-subtle" placeholder="Ej. Márquez" />
                                <span asp-validation-for="Apellido" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4 opacity-50" />

                        <div class="row mb-4">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nacionalidad" class="form-label small fw-bold text-muted text-uppercase">Nacionalidad</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light rounded-start-1 border-secondary-subtle">
                                        <i class="bi bi-globe"></i>
                                    </span>
                                    <input asp-for="Nacionalidad" class="form-control rounded-end-1 border-secondary-subtle" placeholder="Ej. Colombiana" />
                                </div>
                                <span asp-validation-for="Nacionalidad" class="text-danger small"></span>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="Estado" class="form-label small fw-bold text-muted text-uppercase">Estatus en Sistema</label>
                                <select asp-for="Estado" class="form-select rounded-1 border-secondary-subtle">
                                    <option value="true">Activo / Visible</option>
                                    <option value="false">Inactivo / Oculto</option>
                                </select>
                                <span asp-validation-for="Estado" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="text-end pt-3 border-top">
                            <button type="submit" class="btn btn-primary btn-lg px-5 rounded-1 fw-bold border-0">
                                <i class="bi bi-person-check me-1"></i> Registrar Autor
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="mt-3 text-center">
                <p class="text-muted small">
                    <i class="bi bi-info-circle me-1"></i>
                    Al registrar el autor, este podrá ser vinculado a sus respectivas obras en el catálogo bibliográfico.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}