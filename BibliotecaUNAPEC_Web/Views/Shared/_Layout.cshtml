<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Biblioteca UNAPEC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BibliotecaUNAPEC_Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">Biblioteca UNAPEC</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    @* --- Menú principal de la aplicación --- *@
                    <ul class="navbar-nav me-auto mb-2 mb-sm-0 gap-3 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark text-nowrap" asp-area="" asp-controller="Libros" asp-action="Index">Catálogo de Libros</a>
                            </li>

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-danger fw-bold text-nowrap" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        Gestión Administrativa
                                    </a>
                                    <ul class="dropdown-menu shadow" aria-labelledby="navbarDropdown">
                                        <li><h6 class="dropdown-header">Mantenimientos Base</h6></li>
                                        <li><a class="dropdown-item" asp-controller="Autores" asp-action="Index">Autores</a></li>
                                        <li><a class="dropdown-item" asp-controller="Editoriales" asp-action="Index">Editoriales</a></li>
                                        <li><a class="dropdown-item" asp-controller="Ciencias" asp-action="Index">Ciencias</a></li>
                                        <li><a class="dropdown-item" asp-controller="Idiomas" asp-action="Index">Idiomas</a></li>

                                        @* --- CORRECCIÓN APLICADA AQUÍ: TiposBibliografiums --- *@
                                        <li><a class="dropdown-item" asp-controller="TiposBibliografiums" asp-action="Index">Tipos de Bibliografía</a></li>

                                        <li><hr class="dropdown-divider"></li>
                                        <li><h6 class="dropdown-header">Personal y Usuarios</h6></li>
                                        <li><a class="dropdown-item" asp-controller="Usuarios" asp-action="Index">Usuarios Biblioteca</a></li>
                                        <li><a class="dropdown-item" asp-controller="Empleados" asp-action="Index">Empleados</a></li>
                                    </ul>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link text-success fw-bold text-nowrap" asp-area="" asp-controller="PrestamosDevoluciones" asp-action="Index">Préstamos</a>
                            </li>
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            &copy; 2026 - Biblioteca UNAPEC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>