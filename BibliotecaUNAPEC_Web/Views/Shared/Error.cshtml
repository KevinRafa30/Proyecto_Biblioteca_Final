@using BibliotecaUNAPEC_Web.Models
@model ErrorViewModel
@{
    ViewData["Title"] = "Error en el Sistema";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="mb-4">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4rem;"></i>
            </div>
            
            <h1 class="display-5 fw-bold text-dark">¡Ups! Algo salió mal</h1>
            <p class="lead text-muted">Hubo un inconveniente al procesar tu solicitud en la plataforma de la biblioteca.</p>

            <div class="card shadow-sm border-0 my-4">
                <div class="card-body bg-light p-4">
                    @if (Model.ShowRequestId)
                    {
                        <p class="mb-0">
                            <span class="fw-bold">ID de Seguimiento:</span>
                            <code class="bg-white px-2 py-1 rounded border">@Model.RequestId</code>
                        </p>
                    }
                    else
                    {
                        <p class="mb-0 text-muted italic">No hay un ID de error específico registrado.</p>
                    }
                </div>
            </div>

            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg px-4 shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver atrás
                </a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4 shadow-sm">
                    <i class="bi bi-house-door"></i> Ir al Inicio
                </a>
            </div>

            @if (Context.Items["Exception"] != null)
            {
                <div class="mt-5 text-start">
                    <div class="alert alert-warning border-0 shadow-sm">
                        <h5 class="alert-heading fw-bold"><i class="bi bi-bug"></i> Detalles para Desarrollo:</h5>
                        <p class="small mb-0 text-break">@Context.Items["Exception"]</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>