@model BibliotecaUNAPEC_Web.Models.Idioma

@{
    ViewData["Title"] = "Eliminar Idioma";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h2 class="fw-bold text-danger mb-0">Eliminar Idioma</h2>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Volver al Listado
                </a>
            </div>

            @* 1. RESUMEN DE VALIDACIÓN: Captura el error de dependencia enviado desde el controlador *@
            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm mb-4 fw-bold"></div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0 small text-uppercase fw-bold">¿Confirmar eliminación del registro?</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label class="form-label fw-bold small text-muted text-uppercase">Nombre del Idioma</label>
                        <div class="form-control-plaintext border-bottom">@Model.Descripcion</div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label fw-bold small text-muted text-uppercase d-block mb-2">Estado</label>
                        @if (Model.Estado == true)
                        {
                            <span class="badge bg-success py-2 px-3">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger py-2 px-3">Inactivo</span>
                        }
                    </div>

                    <hr class="text-muted" />

                    <div class="alert alert-warning border-0 shadow-sm d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                        <div class="small">
                            <strong>Advertencia:</strong> Esta acción eliminará permanentemente el idioma. Solo podrá completarse si no existen libros vinculados.
                        </div>
                    </div>

                    <form asp-action="Delete">
                        @* Es vital que el name sea "id" para el controlador *@
                        <input type="hidden" name="id" value="@Model.IdIdioma" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold shadow-sm">
                                <i class="bi bi-trash-fill me-2"></i> CONFIRMAR ELIMINACIÓN
                            </button>
                            <a asp-action="Edit" asp-route-id="@Model.IdIdioma" class="btn btn-link text-secondary text-decoration-none small text-center">
                                Cancelar y volver a edición
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>