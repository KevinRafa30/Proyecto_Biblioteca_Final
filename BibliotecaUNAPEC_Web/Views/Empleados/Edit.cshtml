@model BibliotecaUNAPEC_Web.Models.Empleado

@{
    ViewData["Title"] = "Editar Empleado";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-primary">Editar Perfil de Empleado</h2>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Personal
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0">Información Laboral y Personal</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="IdEmpleado" />

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="Nombre" class="form-label fw-bold text-dark">Nombre Completo</label>
                                    <input asp-for="Nombre" class="form-control" placeholder="Ej. Juan Pérez" />
                                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="Cedula" class="form-label fw-bold text-dark">Cédula de Identidad</label>
                                    <input asp-for="Cedula" class="form-control" placeholder="000-0000000-0" />
                                    <span asp-validation-for="Cedula" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label asp-for="TandaLaboral" class="form-label fw-bold text-dark">Tanda Laboral</label>
                                    <select asp-for="TandaLaboral" class="form-select">
                                        <option value="">Seleccione una tanda...</option>
                                        <option value="Matutina">Matutina</option>
                                        <option value="Vespertina">Vespertina</option>
                                        <option value="Nocturna">Nocturna</option>
                                    </select>
                                    <span asp-validation-for="TandaLaboral" class="text-danger small"></span>
                                </div>

                                <div class="form-group mb-3">
                                    <label asp-for="FechaIngreso" class="form-label fw-bold text-dark">Fecha de Ingreso</label>
                                    <input asp-for="FechaIngreso" class="form-control" type="date" />
                                    <span asp-validation-for="FechaIngreso" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4 text-muted" />

                        <div class="form-group mb-4 text-center">
                            <label class="form-label fw-bold d-block">Estado del Empleado</label>
                            <div class="form-check form-switch d-inline-block">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       name="Estado" id="switchEstado" value="true"
                                @(Model.Estado == true ? "checked=\"checked\"" : "")>
                                <input type="hidden" name="Estado" value="false" />
                                <label class="form-check-label text-muted ms-2" for="switchEstado">
                                    ¿Empleado activo en nómina?
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="bi bi-person-check"></i> Actualizar Expediente
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}