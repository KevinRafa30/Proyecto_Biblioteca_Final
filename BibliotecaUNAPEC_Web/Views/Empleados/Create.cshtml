@model BibliotecaUNAPEC_Web.Models.Empleado

@{
    ViewData["Title"] = "Registrar Empleado";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h2 class="fw-bold text-primary mb-0">Gestión de Personal</h2>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Volver al Listado
                </a>
            </div>

            <div class="card rounded-1 border shadow-none">
                <div class="card-header bg-light border-bottom p-3">
                    <h6 class="mb-0 fw-bold text-dark text-uppercase small">
                        <i class="bi bi-person-badge me-2 text-primary"></i>Alta de Nuevo Colaborador
                    </h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        @* SEGURO 1: Resumen de validación del servidor *@
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small mb-3 fw-bold"></div>

                        <div class="row mb-4">
                            <div class="col-md-8 mb-3">
                                <label asp-for="Nombre" class="form-label small fw-bold text-muted text-uppercase">Nombre Completo</label>
                                @* SEGURO 2: Límite de 100 caracteres *@
                                <input asp-for="Nombre" class="form-control rounded-1 border-secondary-subtle" placeholder="Ej. María Rodríguez" maxlength="100" required />
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Cedula" class="form-label small fw-bold text-muted text-uppercase">Cédula (Solo números)</label>
                                @* SEGURO 3: Bloqueo de letras y límite de 11 *@
                                <input asp-for="Cedula" class="form-control rounded-1 border-secondary-subtle font-monospace"
                                       placeholder="Ej. 00123456789"
                                       maxlength="11"
                                       required
                                       oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                                <span asp-validation-for="Cedula" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4 opacity-50" />

                        <div class="row mb-4">
                            <div class="col-md-4 mb-3">
                                <label asp-for="TandaLaboral" class="form-label small fw-bold text-muted text-uppercase">Tanda Laboral</label>
                                @* SEGURO 4: Select para evitar textos manuales largos *@
                                <select asp-for="TandaLaboral" class="form-select rounded-1 border-secondary-subtle" required>
                                    <option value="">-- Seleccionar --</option>
                                    <option value="Matutina">Matutina (Mañana)</option>
                                    <option value="Vespertina">Vespertina (Tarde)</option>
                                    <option value="Nocturna">Nocturna (Noche)</option>
                                </select>
                                <span asp-validation-for="TandaLaboral" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="FechaIngreso" class="form-label small fw-bold text-muted text-uppercase">Fecha de Ingreso</label>
                                <input asp-for="FechaIngreso" type="date" class="form-control rounded-1 border-secondary-subtle" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                                <span asp-validation-for="FechaIngreso" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Estado" class="form-label small fw-bold text-muted text-uppercase">Estatus Laboral</label>
                                <select asp-for="Estado" class="form-select rounded-1 border-secondary-subtle" required>
                                    <option value="true">Activo / Operativo</option>
                                    <option value="false">Inactivo / Licencia</option>
                                </select>
                                <span asp-validation-for="Estado" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="text-end pt-3 border-top">
                            <button type="submit" class="btn btn-primary btn-lg px-5 rounded-1 fw-bold border-0 shadow-sm">
                                <i class="bi bi-save2 me-1"></i> Registrar Empleado
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* SEGURO 5: El motor que hace que el botón de guardar se bloquee ante errores *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}