@model BibliotecaUNAPEC_Web.Models.Empleado

@{
    ViewData["Title"] = "Registrar Empleado";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Registrar Nuevo Empleado</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <h5 class="text-secondary mb-3">Datos Personales</h5>
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Nombre" class="control-label fw-bold">Nombre Completo</label>
                                <input asp-for="Nombre" class="form-control" placeholder="Ej. María Rodríguez" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Cedula" class="control-label fw-bold">Cédula de Identidad</label>
                                <input asp-for="Cedula" class="form-control" placeholder="Ej. 001-0000000-1" />
                                <span asp-validation-for="Cedula" class="text-danger"></span>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <h5 class="text-secondary mb-3">Información Laboral</h5>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="TandaLaboral" class="control-label fw-bold">Tanda Laboral</label>
                                <select asp-for="TandaLaboral" class="form-select">
                                    <option value="">-- Seleccione --</option>
                                    <option value="Matutina">Matutina</option>
                                    <option value="Vespertina">Vespertina</option>
                                    <option value="Nocturna">Nocturna</option>
                                </select>
                                <span asp-validation-for="TandaLaboral" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="FechaIngreso" class="control-label fw-bold">Fecha de Ingreso</label>
                                <input asp-for="FechaIngreso" type="date" class="form-control" />
                                <span asp-validation-for="FechaIngreso" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="Estado" class="control-label fw-bold">Estado del Empleado</label>
                                <select asp-for="Estado" class="form-select">
                                    <option value="true">Activo</option>
                                    <option value="false">Inactivo</option>
                                </select>
                                <span asp-validation-for="Estado" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">Volver al Listado</a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">Guardar Empleado</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}