@model BibliotecaUNAPEC_Web.Models.Ciencia

@{
    ViewData["Title"] = "Eliminar Ciencia";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-danger">Eliminar Ciencia / Área</h2>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Listado
                </a>
            </div>

            @* RESUMEN DE VALIDACIÓN: Aquí se mostrará el mensaje si tiene libros asociados *@
            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm mb-4 fw-bold"></div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0">¿Confirmar eliminación del área?</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small text-uppercase">Nombre de la Ciencia</label>
                        <div class="form-control-plaintext border-bottom">@Model.Descripcion</div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label fw-bold d-block text-muted small text-uppercase">Estado de la Categoría</label>
                        @if (Model.Estado == true)
                        {
                            <span class="badge bg-success py-2 px-3">Activa</span>
                        }
                        else
                        {
                            <span class="badge bg-danger py-2 px-3">Inactiva</span>
                        }
                    </div>

                    <hr class="text-muted" />

                    <div class="alert alert-warning border-0 shadow-sm d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
                        <div>
                            <strong>Atención:</strong> Esta acción es irreversible. Solo se podrá ejecutar si no hay libros vinculados a esta área.
                        </div>
                    </div>

                    <form asp-action="Delete">
                        @* Se usa el name="id" para asegurar el mapeo con el controlador *@
                        <input type="hidden" name="id" value="@Model.IdCiencia" />

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-danger btn-lg shadow-sm fw-bold">
                                <i class="bi bi-trash"></i> Eliminar Permanentemente
                            </button>
                            @* BOTÓN DE CANCELAR: Coherencia con el estándar de Autores *@
                            <a asp-action="Edit" asp-route-id="@Model.IdCiencia" class="btn btn-link text-secondary text-decoration-none small text-center">
                                Cancelar y volver a edición
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>