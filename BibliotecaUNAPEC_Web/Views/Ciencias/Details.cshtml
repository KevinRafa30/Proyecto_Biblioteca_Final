@model BibliotecaUNAPEC_Web.Models.Ciencia

@{
    ViewData["Title"] = "Detalles de la Ciencia";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-primary">Información de la Ciencia</h2>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Listado
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0">Área del Conocimiento #@Model.IdCiencia</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-3 align-items-center">
                        <div class="col-sm-4 fw-bold text-muted">Nombre/Área:</div>
                        <div class="col-sm-8 fs-4 fw-bold text-dark">@Model.Descripcion</div>
                    </div>

                    <hr class="text-light" />

                    <div class="row mb-3 align-items-center">
                        <div class="col-sm-4 fw-bold text-muted">Estado en el Sistema:</div>
                        <div class="col-sm-8">
                            @if (Model.Estado == true)
                            {
                                <span class="badge bg-success py-2 px-3">
                                    <i class="bi bi-check-circle-fill"></i> Activa
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger py-2 px-3">
                                    <i class="bi bi-x-circle-fill"></i> Inactiva
                                </span>
                            }
                        </div>
                    </div>

                    <div class="mt-4 p-3 bg-light rounded border text-center">
                        <p class="text-muted mb-0 small">
                            <i class="bi bi-info-circle"></i> Esta categoría permite agrupar los libros en el catálogo según su rama científica o académica.
                        </p>
                    </div>
                </div>

                <div class="card-footer bg-white border-top-0 p-3 text-end">
                    <a asp-action="Edit" asp-route-id="@Model?.IdCiencia" class="btn btn-primary px-4 shadow-sm">
                        <i class="bi bi-pencil"></i> Editar Ciencia
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>