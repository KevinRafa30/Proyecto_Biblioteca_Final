@model IEnumerable<BibliotecaUNAPEC_Web.Models.Libro>

@{
    ViewData["Title"] = "Catálogo de Libros";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">Catálogo de Libros</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">Registrar Nuevo Libro</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Título</th>
                            <th>ISBN</th>
                            <th>Año</th>
                            <th>Autor</th>
                            <th>Editorial</th>
                            <th>Ciencia</th>
                            <th>Idioma</th>
                            <th>Formato</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle fw-bold">@item.Titulo</td>
                                <td class="align-middle">@item.Isbn</td>
                                <td class="align-middle">@item.AnioPublicacion</td>

                                <td class="align-middle">@item.IdAutorNavigation.Nombre</td>
                                <td class="align-middle">@item.IdEditorialNavigation.Nombre</td>
                                <td class="align-middle">@item.IdCienciaNavigation.Descripcion</td>
                                <td class="align-middle">@item.IdIdiomaNavigation.Descripcion</td>
                                <td class="align-middle">@item.IdTipoBibliografiaNavigation.Descripcion</td>

                                <td class="align-middle">
                                    @if (item.Estado == true)
                                    {
                                        <span class="badge bg-success py-2 px-3">Disponible</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger py-2 px-3">No Disponible</span>
                                    }
                                </td>
                                <td class="align-middle text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.IdLibro" class="btn btn-sm btn-outline-primary">Editar</a>
                                        <a asp-action="Details" asp-route-id="@item.IdLibro" class="btn btn-sm btn-outline-secondary">Detalles</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>