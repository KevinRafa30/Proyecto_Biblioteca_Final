@model BibliotecaUNAPEC_Web.Models.Libro

@{
    ViewData["Title"] = "Editar Libro";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h2 class="fw-bold text-primary mb-0">Editar Información del Libro</h2>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Volver al Catálogo
                </a>
            </div>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                <input type="hidden" asp-for="IdLibro" />

                <div class="row">
                    @* COLUMNA IZQUIERDA: Datos Generales *@
                    <div class="col-md-6 mb-4">
                        <div class="card rounded-1 border shadow-none h-100">
                            <div class="card-header bg-light border-bottom p-3">
                                <h6 class="mb-0 fw-bold text-dark text-uppercase small">
                                    <i class="bi bi-journal-text me-2 text-primary"></i>Datos Generales
                                </h6>
                            </div>
                            <div class="card-body p-4">
                                <div class="mb-3">
                                    <label asp-for="Titulo" class="form-label small fw-bold text-muted text-uppercase">Título del Libro</label>
                                    <input asp-for="Titulo" class="form-control rounded-1 border-secondary-subtle" placeholder="Ej. El Quijote" />
                                    <span asp-validation-for="Titulo" class="text-danger small"></span>
                                </div>

                                <div class="row mb-3">
                                    <div class="col-md-7">
                                        <label asp-for="Isbn" class="form-label small fw-bold text-muted text-uppercase">ISBN</label>
                                        <input asp-for="Isbn" class="form-control rounded-1 font-monospace" placeholder="000-0000000" />
                                        <span asp-validation-for="Isbn" class="text-danger small"></span>
                                    </div>
                                    <div class="col-md-5">
                                        <label asp-for="AnioPublicacion" class="form-label small fw-bold text-muted text-uppercase">Año</label>
                                        <input asp-for="AnioPublicacion" class="form-control rounded-1" type="number" />
                                        <span asp-validation-for="AnioPublicacion" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="mt-4 pt-3 border-top">
                                    <label class="form-label small fw-bold text-muted text-uppercase d-block mb-3">Disponibilidad del Recurso</label>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch"
                                               name="Estado" id="switchEstado" value="true"
                                               @(Model.Estado == true ? "checked=\"checked\"" : "")>
                                        <input type="hidden" name="Estado" value="false" />
                                        <label class="form-check-label text-dark" for="switchEstado">
                                            Habilitar para préstamo público
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* COLUMNA DERECHA: Clasificación *@
                    <div class="col-md-6 mb-4">
                        <div class="card rounded-1 border shadow-none h-100">
                            <div class="card-header bg-light border-bottom p-3">
                                <h6 class="mb-0 fw-bold text-dark text-uppercase small">
                                    <i class="bi bi-tags me-2 text-primary"></i>Clasificación
                                </h6>
                            </div>
                            <div class="card-body p-4">
                                <div class="mb-3">
                                    <label asp-for="IdAutor" class="form-label small fw-bold text-muted text-uppercase">Autor Responsable</label>
                                    <select asp-for="IdAutor" class="form-select rounded-1" asp-items="ViewBag.IdAutor"></select>
                                    <span asp-validation-for="IdAutor" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="IdEditorial" class="form-label small fw-bold text-muted text-uppercase">Editorial</label>
                                    <select asp-for="IdEditorial" class="form-select rounded-1" asp-items="ViewBag.IdEditorial"></select>
                                    <span asp-validation-for="IdEditorial" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="IdCiencia" class="form-label small fw-bold text-muted text-uppercase">Área del Conocimiento</label>
                                    <select asp-for="IdCiencia" class="form-select rounded-1" asp-items="ViewBag.IdCiencia"></select>
                                    <span asp-validation-for="IdCiencia" class="text-danger small"></span>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <label asp-for="IdIdioma" class="form-label small fw-bold text-muted text-uppercase">Idioma</label>
                                        <select asp-for="IdIdioma" class="form-select rounded-1" asp-items="ViewBag.IdIdioma"></select>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="IdTipoBibliografia" class="form-label small fw-bold text-muted text-uppercase">Formato</label>
                                        <select asp-for="IdTipoBibliografia" class="form-select rounded-1" asp-items="ViewBag.IdTipoBibliografia"></select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* SECCIÓN DE ACCIONES: Guardar y Eliminar apilados *@
                <div class="row justify-content-center mt-2">
                    <div class="col-md-6">
                        <div class="d-grid gap-2 mb-5">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm fw-bold">
                                <i class="bi bi-check-lg me-1"></i> Guardar Cambios
                            </button>
                            <a asp-action="Delete" asp-route-id="@Model.IdLibro" class="btn btn-outline-danger btn-lg shadow-sm">
                                <i class="bi bi-trash me-1"></i> Eliminar Libro del Catálogo
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}