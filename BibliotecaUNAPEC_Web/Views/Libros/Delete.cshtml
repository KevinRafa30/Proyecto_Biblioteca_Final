@model BibliotecaUNAPEC_Web.Models.Libro

@{
    ViewData["Title"] = "Eliminar Libro";

    // Lógica para determinar el estado de bloqueo
    bool estaPrestado = Model.Estado == false;
    var claseAlertaEstado = estaPrestado ? "alert-secondary" : "alert-warning";
    var errorServidor = TempData["ErrorBorrado"] as string;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">

            @* CABECERA: Consistente con el resto del catálogo *@
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-danger mb-0">Eliminar Libro</h2>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Catálogo
                </a>
            </div>

            @* 1. ALERTA DE ERROR: Si el controlador rebotó la acción (Ej. Error de integridad) *@
            @if (!string.IsNullOrEmpty(errorServidor))
            {
                <div class="alert alert-danger border-0 shadow-sm mb-4 fw-bold">
                    <i class="bi bi-x-octagon-fill me-2"></i> @errorServidor
                </div>
            }

            @* 2. ALERTA PREVENTIVA: Si el ViewBag trae un mensaje de bloqueo del GET *@
            @if (ViewBag.MensajeError != null)
            {
                <div class="alert alert-warning border-0 shadow-sm mb-4 fw-bold">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.MensajeError
                </div>
            }

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0 small text-uppercase fw-bold">¿Confirmar desvinculación definitiva del catálogo?</h5>
                </div>

                <div class="card-body p-4">
                    <div class="row mb-4">
                        @* Columna de Información del Libro *@
                        <div class="col-md-8">
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <label class="form-label fw-bold text-muted small text-uppercase">Título del Recurso</label>
                                    <div class="form-control-plaintext border-bottom">@Model.Titulo</div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold text-muted small text-uppercase">Código ISBN</label>
                                    <div class="form-control-plaintext border-bottom font-monospace">@Model.Isbn</div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold text-muted small text-uppercase">Año de Publicación</label>
                                    <div class="form-control-plaintext border-bottom">@Model.AnioPublicacion</div>
                                </div>
                            </div>
                        </div>

                        @* Columna de Estado Visual (Badge) *@
                        <div class="col-md-4 text-center border-start">
                            <label class="form-label fw-bold text-muted small text-uppercase d-block mb-3">Estado del Ejemplar</label>
                            @if (!estaPrestado)
                            {
                                <span class="badge bg-success py-2 px-4 mb-3 fs-6">Disponible</span>
                            }
                            else
                            {
                                <span class="badge bg-danger py-2 px-4 mb-3 fs-6">No Disponible</span>
                            }
                            <div class="text-muted small">
                                <i class="bi bi-info-circle me-1"></i> ID de Registro: #@Model.IdLibro
                            </div>
                        </div>
                    </div>

                    <hr class="text-muted" />

                    @* 3. BLOQUE DE ADVERTENCIA DINÁMICO *@
                    <div class="alert @claseAlertaEstado border-0 shadow-sm d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-exclamation-octagon-fill me-3 fs-3"></i>
                        <div>
                            @if (estaPrestado)
                            {
                                <strong>Acción Bloqueada:</strong>
                                <span>No es posible eliminar este libro porque tiene un préstamo activo. El usuario debe devolver el material antes de proceder.</span>
                            }
                            else
                            {
                                <strong>Advertencia de Seguridad:</strong>
                                <span>Esta acción es permanente. Se eliminarán todos los registros asociados a este libro del inventario general.</span>
                            }
                        </div>
                    </div>

                    @* FORMULARIO DE ELIMINACIÓN *@
                    <form asp-action="Delete">
                        @* ID oculto fundamental para el controlador *@
                        <input type="hidden" name="id" value="@Model.IdLibro" />

                        <div class="d-grid gap-2">
                            @if (estaPrestado)
                            {
                                @* Botón deshabilitado si el libro está prestado *@
                                <button type="button" class="btn btn-danger btn-lg fw-bold shadow-sm opacity-50" disabled>
                                    <i class="bi bi-slash-circle me-2"></i> ELIMINACIÓN DESHABILITADA
                                </button>
                            }
                            else
                            {
                                @* Botón activo si el libro está libre *@
                                <button type="submit" class="btn btn-danger btn-lg fw-bold shadow-sm">
                                    <i class="bi bi-trash-fill me-2"></i> CONFIRMAR ELIMINACIÓN PERMANENTE
                                </button>
                            }

                            <a asp-action="Edit" asp-route-id="@Model.IdLibro" class="btn btn-link text-secondary text-decoration-none">
                                Cancelar y volver al registro
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>