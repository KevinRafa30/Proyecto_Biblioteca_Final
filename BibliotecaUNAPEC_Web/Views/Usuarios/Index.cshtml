@model IEnumerable<BibliotecaUNAPEC_Web.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">Gestión de Usuarios de Biblioteca</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-person-plus-fill me-1"></i> Registrar Nuevo Usuario
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Nombre Completo</th>
                            <th>Cédula</th>
                            <th>No. de Carnet</th>
                            <th>Tipo de Persona</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle fw-bold ps-4">@item.Nombre</td>
                                <td class="align-middle">@item.Cedula</td>
                                <td class="align-middle">@item.NoCarnet</td>
                                <td class="align-middle">@item.TipoPersona</td>
                                <td class="align-middle text-center">
                                    @if (item.Estado == true)
                                    {
                                        <span class="badge bg-success py-2 px-3">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger py-2 px-3">Inactivo</span>
                                    }
                                </td>
                                <td class="align-middle text-center pe-4">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.IdUsuario" class="btn btn-sm btn-outline-primary" title="Editar">
                                            <i class="bi bi-pencil"></i> Editar
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.IdUsuario" class="btn btn-sm btn-outline-secondary" title="Detalles">
                                            <i class="bi bi-eye"></i> Detalles
                                        </a>
                                        
                                        <a asp-action="Delete" asp-route-id="@item.IdUsuario" class="btn btn-sm btn-outline-danger" title="Borrar">
                                            <i class="bi bi-trash"></i> Borrar
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>