@model BibliotecaUNAPEC_Web.Models.Usuario

@{
    ViewData["Title"] = "Eliminar Usuario";

    // Capturamos el estado de bloqueo desde el controlador
    bool estaBloqueado = ViewBag.Bloqueado ?? false;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-danger">Eliminar Usuario</h2>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Listado
                </a>
            </div>

            @* 1. RESUMEN DE VALIDACIÓN: Aquí aparecerá el error enviado desde el ModelState del controlador *@
            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm mb-4 fw-bold"></div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0">¿Está seguro de que desea eliminar este usuario?</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-muted small text-uppercase">Nombre Completo</label>
                            <div class="form-control-plaintext border-bottom">@Model.Nombre</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-muted small text-uppercase">Cédula</label>
                            <div class="form-control-plaintext border-bottom">@Model.Cedula</div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-muted small text-uppercase">No. de Carnet</label>
                            <div class="form-control-plaintext border-bottom">@Model.NoCarnet</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-muted small text-uppercase">Clasificación</label>
                            <div class="form-control-plaintext border-bottom">@Model.TipoPersona</div>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label fw-bold d-block text-muted small text-uppercase">Estado de la Cuenta</label>
                        @if (Model.Estado == true)
                        {
                            <span class="badge bg-success py-2 px-3">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger py-2 px-3">Inactivo</span>
                        }
                    </div>

                    <hr class="text-muted" />

                    @* 2. ALERTA AMARILLA: Dinámica según el estado de bloqueo *@
                    <div class="alert alert-warning border-0 shadow-sm d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
                        <div>
                            @if (estaBloqueado)
                            {
                                <strong>Acción Protegida:</strong> <span>@ViewBag.MensajeBloqueo</span>
                            }
                            else
                            {
                                <strong>Atención:</strong> <span>Esta acción eliminará permanentemente los datos del usuario. Solo se puede realizar si no tiene préstamos registrados.</span>
                            }
                        </div>
                    </div>

                    <form asp-action="Delete">
                        @* ID oculto con name="id" para el controlador *@
                        <input type="hidden" name="id" value="@Model.IdUsuario" />

                        <div class="d-grid gap-2 mt-4">
                            @if (estaBloqueado)
                            {
                                <button type="button" class="btn btn-danger btn-lg shadow-sm fw-bold opacity-50" disabled>
                                    <i class="bi bi-lock-fill me-2"></i> Eliminación Bloqueada
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-danger btn-lg shadow-sm fw-bold">
                                    <i class="bi bi-trash"></i> Confirmar Eliminación Permanente
                                </button>
                            }
                            
                            <a asp-action="Edit" asp-route-id="@Model.IdUsuario" class="btn btn-link text-secondary text-decoration-none small text-center">
                                Cancelar y volver a edición
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>