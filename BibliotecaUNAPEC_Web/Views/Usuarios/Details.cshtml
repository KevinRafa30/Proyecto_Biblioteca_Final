@model BibliotecaUNAPEC_Web.Models.Usuario

@{
    ViewData["Title"] = "Expediente de Usuario";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-primary">Perfil del Usuario</h2>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Listado
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Ficha de Miembro #@Model.IdUsuario</h5>
                    <span class="badge bg-primary">@Model.TipoPersona</span>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-6 border-end">
                            <h6 class="text-primary fw-bold text-uppercase small mb-3">Identidad Legal</h6>
                            <div class="mb-3">
                                <label class="text-muted d-block small">Nombre Completo</label>
                                <span class="fs-5 fw-bold">@Model.Nombre</span>
                            </div>
                            <div class="mb-3">
                                <label class="text-muted d-block small">Cédula</label>
                                <span class="font-monospace">@Model.Cedula</span>
                            </div>
                        </div>

                        <div class="col-md-6 ps-md-4">
                            <h6 class="text-primary fw-bold text-uppercase small mb-3">Acceso Biblioteca</h6>
                            <div class="mb-3">
                                <label class="text-muted d-block small">No. de Carnet</label>
                                <span class="badge bg-light text-dark fs-6 border">@Model.NoCarnet</span>
                            </div>
                            <div class="mb-3">
                                <label class="text-muted d-block small">Estado de Préstamos</label>
                                @if (Model.Estado == true)
                                {
                                    <span class="badge bg-success py-2 px-3">
                                        <i class="bi bi-check-circle"></i> Habilitado
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger py-2 px-3">
                                        <i class="bi bi-slash-circle"></i> Suspendido
                                    </span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 p-3 bg-light rounded border text-center">
                        <small class="text-muted">
                            <i class="bi bi-info-circle"></i> Este carnet es personal e intransferible. El usuario debe presentarlo para solicitar cualquier recurso bibliográfico.
                        </small>
                    </div>
                </div>

                <div class="card-footer bg-white border-top-0 p-3 text-end">
                    <a asp-action="Edit" asp-route-id="@Model?.IdUsuario" class="btn btn-primary px-4 shadow-sm">
                        <i class="bi bi-pencil"></i> Editar Usuario
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>