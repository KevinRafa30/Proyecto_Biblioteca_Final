@model BibliotecaUNAPEC_Web.Models.Usuario

@{
    ViewData["Title"] = "Registrar Usuario";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h2 class="fw-bold text-primary mb-0">Gestión de Usuarios</h2>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Volver al Listado
                </a>
            </div>

            <div class="card rounded-1 border shadow-none">
                <div class="card-header bg-dark p-3">
                    <h6 class="mb-0 fw-bold text-white text-uppercase small">
                        <i class="bi bi-person-plus me-2 text-primary"></i>Registro de Afiliado
                    </h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        @* SEGURO 1: Errores de servidor *@
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm mb-4 fw-bold small"></div>

                        <div class="row mb-4">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Nombre" class="form-label small fw-bold text-muted text-uppercase">Nombre Completo</label>
                                <input asp-for="Nombre" class="form-control rounded-1 border-secondary-subtle" placeholder="Ej. Juan Pérez" maxlength="100" />
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Cedula" class="form-label small fw-bold text-muted text-uppercase">Cédula (Solo números)</label>
                                @* SEGURO 3: Bloqueo de guiones y letras *@
                                <input asp-for="Cedula" class="form-control rounded-1 border-secondary-subtle font-monospace"
                                       placeholder="Ej. 00100000001"
                                       maxlength="11"
                                       oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                                <small class="text-muted d-block mt-1" style="font-size: 0.75rem;">Exactamente 11 dígitos numéricos.</small>
                                <span asp-validation-for="Cedula" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="NoCarnet" class="form-label small fw-bold text-muted text-uppercase">Número de Carnet (Solo números)</label>
                                @* SEGURO 6 (NUEVO): Ahora el Carnet también bloquea letras físicamente *@
                                <input asp-for="NoCarnet" class="form-control rounded-1 border-secondary-subtle font-monospace"
                                       placeholder="Solo dígitos"
                                       maxlength="20"
                                       oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                                <span asp-validation-for="NoCarnet" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4 opacity-50" />

                        <div class="row mb-4">
                            <div class="col-md-6 mb-3">
                                <label asp-for="TipoPersona" class="form-label small fw-bold text-muted text-uppercase">Clasificación de Usuario</label>
                                <select asp-for="TipoPersona" class="form-select rounded-1 border-secondary-subtle">
                                    <option value="">-- Seleccionar categoría --</option>
                                    <option value="Estudiante">Estudiante</option>
                                    <option value="Profesor">Profesor</option>
                                    <option value="Empleado">Empleado Administrativo</option>
                                    <option value="Externo">Visitante Externo</option>
                                </select>
                                <span asp-validation-for="TipoPersona" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Estado" class="form-label small fw-bold text-muted text-uppercase">Estatus de Cuenta</label>
                                <select asp-for="Estado" class="form-select rounded-1 border-secondary-subtle">
                                    <option value="true">Activo (Habilitado)</option>
                                    <option value="false">Inactivo (Suspendido)</option>
                                </select>
                                <span asp-validation-for="Estado" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="text-end pt-3 border-top">
                            <button type="submit" class="btn btn-primary btn-lg px-5 rounded-1 fw-bold border-0 shadow-sm">
                                <i class="bi bi-save2 me-1"></i> Guardar Usuario
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}