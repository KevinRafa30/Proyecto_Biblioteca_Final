@model BibliotecaUNAPEC_Web.Models.PrestamosDevolucione

@{
    ViewData["Title"] = "Nuevo Préstamo";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h2 class="fw-bold text-primary mb-0">Registrar Nuevo Préstamo</h2>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Volver al Listado
                </a>
            </div>

            <div class="card rounded-1 border shadow-none">
                <div class="card-header bg-light border-bottom p-3">
                    <h6 class="mb-0 fw-bold text-dark text-uppercase small">
                        <i class="bi bi-clipboard-check me-2 text-primary"></i>Formulario de Transacción
                    </h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="row mb-4">
                            <div class="col-md-12 mb-3">
                                <label asp-for="IdLibro" class="form-label small fw-bold text-muted text-uppercase">Libro Solicitado</label>
                                <select asp-for="IdLibro" class="form-select rounded-1 border-secondary-subtle" asp-items="ViewBag.IdLibro">
                                    <option value="">-- Seleccionar ejemplar del catálogo --</option>
                                </select>
                                <span asp-validation-for="IdLibro" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="IdUsuario" class="form-label small fw-bold text-muted text-uppercase">Usuario / Estudiante</label>
                                <select asp-for="IdUsuario" class="form-select rounded-1 border-secondary-subtle" asp-items="ViewBag.IdUsuario">
                                    <option value="">-- Identificar usuario --</option>
                                </select>
                                <span asp-validation-for="IdUsuario" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="IdEmpleado" class="form-label small fw-bold text-muted text-uppercase">Bibliotecario en Turno</label>
                                <select asp-for="IdEmpleado" class="form-select rounded-1 border-secondary-subtle" asp-items="ViewBag.IdEmpleado"></select>
                                <span asp-validation-for="IdEmpleado" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4 opacity-50" />

                        <div class="row mb-4">
                            <div class="col-md-4 mb-3">
                                <label asp-for="FechaPrestamo" class="form-label small fw-bold text-muted text-uppercase">Fecha de Salida</label>
                                <input asp-for="FechaPrestamo" class="form-control rounded-1" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="FechaPrestamo" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="CantidadDias" class="form-label small fw-bold text-muted text-uppercase">Días de Préstamo</label>
                                <input asp-for="CantidadDias" class="form-control rounded-1" type="number" placeholder="Ej. 7" />
                                <span asp-validation-for="CantidadDias" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="MontoPorDia" class="form-label small fw-bold text-muted text-uppercase">Costo Diario (RD$)</label>
                                <input asp-for="MontoPorDia" class="form-control rounded-1" placeholder="0.00" />
                                <span asp-validation-for="MontoPorDia" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Comentario" class="form-label small fw-bold text-muted text-uppercase">Notas u Observaciones</label>
                            <textarea asp-for="Comentario" class="form-control rounded-1" rows="2" placeholder="Describa el estado físico del libro al momento de la entrega..."></textarea>
                        </div>

                        <input type="hidden" asp-for="Estado" value="true" />

                        <div class="text-end pt-3 border-top">
                            <button type="submit" class="btn btn-primary btn-lg px-5 rounded-1 fw-bold border-0">
                                <i class="bi bi-check-lg me-1"></i> Confirmar Salida
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}