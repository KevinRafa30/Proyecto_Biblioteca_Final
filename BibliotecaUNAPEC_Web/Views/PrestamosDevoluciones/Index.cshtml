@model IEnumerable<BibliotecaUNAPEC_Web.Models.PrestamosDevolucione>

@{
    ViewData["Title"] = "Control de Préstamos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">Control de Préstamos y Devoluciones</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm">Registrar Nuevo Préstamo</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Libro</th>
                            <th>Usuario</th>
                            <th>Fecha de Salida</th>
                            <th>Plazo Acordado</th>
                            <th>Estado Actual</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle fw-bold">@item.IdLibroNavigation.Titulo</td>
                                <td class="align-middle">@item.IdUsuarioNavigation.Nombre</td>
                                <td class="align-middle">@item.FechaPrestamo</td>
                                <td class="align-middle">@item.CantidadDias días</td>
                                <td class="align-middle">
                                    @* Evaluación del estado de la transacción *@
                                    @if (item.FechaDevolucion == null)
                                    {
                                        <span class="badge bg-warning text-dark py-2 px-3">Pendiente / En Uso</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success py-2 px-3">Devuelto el @item.FechaDevolucion</span>
                                    }
                                </td>
                                <td class="align-middle text-center">
                                    <div class="btn-group" role="group">
                                        @if (item.FechaDevolucion == null)
                                        {
                                            @* Utilizarla llave correcta: IdTransaccion *@
                                            <a asp-action="Edit" asp-route-id="@item.IdTransaccion" class="btn btn-sm btn-success fw-bold">Procesar Devolución</a>
                                        }
                                        <a asp-action="Details" asp-route-id="@item.IdTransaccion" class="btn btn-sm btn-outline-secondary">Ver Detalles</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>