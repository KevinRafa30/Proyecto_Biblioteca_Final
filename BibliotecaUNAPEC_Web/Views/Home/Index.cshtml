@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-5">
    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm border">
        <div class="container-fluid py-2">
            <h1 class="display-5 fw-bold text-primary mb-3">Sistema de Gestión Bibliotecaria UNAPEC</h1>

            @if (!User.Identity.IsAuthenticated)
            {
                <p class="fs-4 text-muted">
                    Bienvenido al portal central de la biblioteca. Este sistema permite la administración eficiente del catálogo bibliográfico y el control de los procesos de préstamos y devoluciones. Inicie sesión para acceder a las funcionalidades correspondientes a su nivel de acceso.
                </p>
                <div class="mt-4">
                    <a class="btn btn-primary btn-lg px-4" href="/Identity/Account/Login">Iniciar Sesión</a>
                </div>
            }
            else
            {
                <p class="fs-4 text-muted">
                    Sesión iniciada. A continuación, se detallan las funcionalidades y módulos a los que tiene acceso según su perfil:
                </p>

                <div class="row mt-5">
                    <div class="col-md-6 mb-4">
                        <div class="card h-100 border-secondary shadow-sm">
                            <div class="card-header bg-secondary text-white fw-bold">
                                Servicios de Biblioteca y Catálogo
                            </div>
                            <div class="card-body d-flex flex-column">
                                <p class="card-text">Funcionalidades operativas disponibles:</p>
                                <ul>
                                    <li>Consultar el catálogo general de libros, revistas, tesis y otros materiales.</li>
                                    <li>Verificar la disponibilidad del inventario bibliográfico en tiempo real.</li>
                                    <li>Procesar operaciones de consulta vinculadas a los recursos físicos de la institución.</li>
                                </ul>
                                <div class="mt-auto">
                                    <a class="btn btn-outline-secondary" asp-controller="Libros" asp-action="Index">Acceder al Catálogo</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="col-md-6 mb-4">
                            <div class="card h-100 border-primary shadow-sm">
                                <div class="card-header bg-primary text-white fw-bold">
                                    Administración del Sistema
                                </div>
                                <div class="card-body d-flex flex-column">
                                    <p class="card-text">Nivel de acceso administrativo que otorga control sobre:</p>
                                    <ul>
                                        <li>Mantenimiento de bases de datos: Registro y actualización de bibliografía, autores, editoriales, ciencias e idiomas.</li>
                                        <li>Gestión de registros de personal (Empleados) y usuarios de la biblioteca.</li>
                                        <li>Auditoría y control de todas las transacciones de préstamos y devoluciones.</li>
                                    </ul>
                                    <div class="mt-auto">
                                        <a class="btn btn-outline-primary" asp-controller="PrestamosDevoluciones" asp-action="Index">Gestión de Préstamos</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>