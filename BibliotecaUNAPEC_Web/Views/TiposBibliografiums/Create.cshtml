@model BibliotecaUNAPEC_Web.Models.TiposBibliografium

@{
    ViewData["Title"] = "Registrar Tipo de Bibliografía";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h2 class="fw-bold text-primary mb-0">Nuevo Formato</h2>
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Volver al Listado
                </a>
            </div>

            <div class="card rounded-1 border shadow-none">
                <div class="card-header bg-light border-bottom p-3">
                    <h6 class="mb-0 fw-bold text-dark text-uppercase small">
                        <i class="bi bi-layers me-2 text-primary"></i>Definición de Formato Bibliográfico
                    </h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="mb-4">
                            <label asp-for="Descripcion" class="form-label small fw-bold text-muted text-uppercase">Descripción del Formato</label>
                            <input asp-for="Descripcion" class="form-control rounded-1 border-secondary-subtle" placeholder="Ej. Libro, Revista, Tesis, CD-ROM..." />
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Estado" class="form-label small fw-bold text-muted text-uppercase">Estado en el Catálogo</label>
                            <select asp-for="Estado" class="form-select rounded-1 border-secondary-subtle">
                                <option value="true">Activo / Disponible</option>
                                <option value="false">Inactivo / Fuera de Uso</option>
                            </select>
                            <span asp-validation-for="Estado" class="text-danger small"></span>
                        </div>

                        <hr class="my-4 opacity-50" />

                        <div class="text-end pt-2">
                            <button type="submit" class="btn btn-primary btn-lg px-5 rounded-1 fw-bold border-0">
                                <i class="bi bi-save2 me-1"></i> Guardar Formato
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="mt-3 text-center">
                <p class="text-muted small">
                    <i class="bi bi-info-circle me-1"></i>
                    Este formato aparecerá como opción al clasificar nuevos libros.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}