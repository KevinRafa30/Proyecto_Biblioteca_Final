@model BibliotecaUNAPEC_Web.Models.TiposBibliografium

@{
    ViewData["Title"] = "Eliminar Formato";
    // Detectamos si el controlador marcó el registro como bloqueado
    bool estaBloqueado = ViewBag.Bloqueado != null && (bool)ViewBag.Bloqueado;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-danger">Eliminar Formato</h2>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Listado
                </a>
            </div>

            @* 1. RESUMEN DE VALIDACIÓN: Aquí aparecerá el error del ModelState (Cuadro Rojo) *@
            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm mb-4 fw-bold"></div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0">¿Está seguro de que desea eliminar este formato?</h5>
                </div>
                <div class="card-body p-4">

                    <div class="form-group mb-4">
                        <label class="form-label fw-bold text-muted">Descripción del Formato</label>
                        <div class="form-control-plaintext border-bottom">@Model.Descripcion</div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label fw-bold d-block text-muted">Estado del Registro</label>
                        @if (Model.Estado == true)
                        {
                            <span class="badge bg-success py-2 px-3">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger py-2 px-3">Inactivo</span>
                        }
                    </div>

                    <hr class="text-muted" />

                    @* Alerta Amarilla: Muestra el mensaje de bloqueo si existe, o la advertencia estándar *@
                    <div class="alert alert-warning border-0 shadow-sm d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
                        <div>
                            @if (estaBloqueado)
                            {
                                <strong>Atención:</strong> @ViewBag.MensajeBloqueo
                            }
                            else
                            {
                                <strong>Atención:</strong> <span>Esta acción eliminará permanentemente los datos del formato. No se puede deshacer si existen dependencias.</span>
                            }
                        </div>
                    </div>

                    <form asp-action="Delete">
                        @* ID con name="id" para que el controlador lo reciba correctamente *@
                        <input type="hidden" name="id" value="@Model.IdTipoBibliografia" />

                        <div class="d-grid gap-2 mt-4">
                            @if (estaBloqueado)
                            {
                                @* Botón deshabilitado si hay libros asociados *@
                                <button type="submit" class="btn btn-danger btn-lg shadow-sm" disabled>
                                    <i class="bi bi-trash"></i> Confirmar Eliminación Permanente
                                </button>
                            }
                            else
                            {
                                @* Botón habilitado normal *@
                                <button type="submit" class="btn btn-danger btn-lg shadow-sm">
                                    <i class="bi bi-trash"></i> Confirmar Eliminación Permanente
                                </button>
                            }

                            <a asp-action="Edit" asp-route-id="@Model.IdTipoBibliografia" class="btn btn-link text-secondary text-decoration-none small text-center">
                                Cancelar y volver a edición
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>