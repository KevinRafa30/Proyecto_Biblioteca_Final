@model BibliotecaUNAPEC_Web.Models.TiposBibliografium

@{
    ViewData["Title"] = "Detalles del Tipo";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-primary">Detalles del Formato</h2>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver al Listado
                </a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0">Ficha de Información Académica</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold text-muted">ID del Registro:</div>
                        <div class="col-sm-8 text-primary fw-bold">#@Model.IdTipoBibliografia</div>
                    </div>
                    
                    <hr class="text-muted" />

                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold text-muted">Nombre/Descripción:</div>
                        <div class="col-sm-8 fs-5">@Model.Descripcion</div>
                    </div>

                    <hr class="text-muted" />

                    <div class="row mb-3 align-items-center">
                        <div class="col-sm-4 fw-bold text-muted">Estado del Tipo:</div>
                        <div class="col-sm-8">
                            @if (Model.Estado == true)
                            {
                                <span class="badge bg-success py-2 px-3">
                                    <i class="bi bi-check-circle-fill"></i> Activo / Disponible
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger py-2 px-3">
                                    <i class="bi bi-x-circle-fill"></i> Inactivo / Restringido
                                </span>
                            }
                        </div>
                    </div>

                    <div class="mt-4 p-3 bg-light rounded border">
                        <small class="text-muted d-block">
                            <i class="bi bi-info-circle"></i> Este tipo de bibliografía se utiliza para categorizar los recursos dentro del catálogo general de la Biblioteca UNAPEC.
                        </small>
                    </div>
                </div>

                <div class="card-footer bg-white border-top-0 p-3 text-end">
                    <a asp-action="Edit" asp-route-id="@Model?.IdTipoBibliografia" class="btn btn-primary px-4 shadow-sm">
                        <i class="bi bi-pencil"></i> Editar este registro
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>